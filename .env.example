# ─────────────────────────────────────────────────────────────
#  AI Front-Desk — environment configuration
#  Copy this file to ".env" and fill in your values.
# ─────────────────────────────────────────────────────────────

# --- Server ---
PORT=3000
# The public base URL of this server (used to build Twilio webhook URLs in docs/logs).
# On Hostinger this is your domain, e.g. https://agent.yourdomain.com
PUBLIC_BASE_URL=http://localhost:3000
NODE_ENV=production

# --- Claude (Anthropic) ---
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx
# Model id. Check current ids at https://docs.claude.com — Sonnet is a good
# quality/latency balance for live phone calls; Haiku is fastest/cheapest.
CLAUDE_MODEL=claude-sonnet-4-6
# Max tokens per agent reply (keep modest for snappy voice turns)
CLAUDE_MAX_TOKENS=600

# --- Twilio ---
# https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
# A Twilio number you own, used as the "from" for owner notifications, e.g. +15551234567
TWILIO_NOTIFY_FROM=+15551234567
# Set to "true" to reject inbound webhooks that fail Twilio signature validation.
# Strongly recommended in production. Requires PUBLIC_BASE_URL to be correct.
TWILIO_VALIDATE_SIGNATURE=true

# --- Dashboard admin login (single operator account) ---
ADMIN_EMAIL=owner@example.com
# This is a PLAINTEXT password only for first boot; on first login the app stores
# a salted hash. You can rotate it from the dashboard later.
ADMIN_PASSWORD=change-me-now
# Random string used to sign session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string

# --- Email notifications (optional; SMTP) ---
# Leave SMTP_HOST blank to disable email and use SMS-only owner alerts.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="AI Front-Desk <no-reply@yourdomain.com>"

# --- Database ---
# Path to the SQLite file (default). To migrate to Hostinger MySQL, see README.
DB_PATH=./data/frontdesk.db

# --- OpenClaw / machine integration ---
# Bearer token that lets your OpenClaw agent (or any backend) call /integration/*.
# Generate with: openssl rand -hex 24. Leave blank to disable the integration API.
INTEGRATION_TOKEN=
